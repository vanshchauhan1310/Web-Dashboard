# ── Database (Supabase / Neon / any Postgres) ──────────────────────────────────
# Option A: full connection string
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname

# Option B: individual fields (assembled automatically by config.py)
user=your_db_user
password=your_db_password
host=your_db_host
port=5432
dbname=postgres

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Token lifetime in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API
# Local dev defaults are already built-in; add your production URL here
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── App metadata (optional) ───────────────────────────────────────────────────
PROJECT_NAME=Enterprise Analytics Dashboard Platform
API_V1_STR=/api/v1
